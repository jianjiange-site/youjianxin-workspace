# ===========================================================================
# ai-chat 运行配置模板。复制为本地 .env 后填密钥:  cp env.example .env
#
# 红线 #1:本文件入库,密钥一律占位(your_xxx);真值只写本地 .env(已 gitignore)。
#   - 共享 dev 基建口令(PG / Nacos 密码)见 docs/dev-onboarding.md §0 速查表
#   - LLM / 三方 key 自备
# 隔离前缀: youjianxin-dating-dev(见仓库根 CLAUDE.md)
# ===========================================================================

# ---- LangSmith 可观测(可选) ----
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=ai-chat

# ---- 环境 ----
ENV=dev

# ---- LLM key(DH 聊天:DeepSeek)----
DEEPSEEK_API_KEY=your_deepseek_api_key

# ---- vision 多模态(图像理解 / 颜值打分 / 头像分析),SmartRouter round_robin 路由 groq→gemini→zai ----
GROQ_API_KEY=your_groq_api_key
GOOGLE_API_KEY=your_google_api_key
ZAI_API_KEY=your_zai_api_key
# 可选:覆盖默认多模态模型 id / Z.ai endpoint
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GEMINI_VISION_MODEL=gemini-3.1-flash-lite
# ZAI_VISION_MODEL=glm-4v-flash
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# ---- gRPC 服务 ----
GRPC_LISTEN_ADDR=[::]:50051
# 配了 Nacos 时走服务发现解析 user-service;此处为 Nacos 不可用时的静态兜底
USER_SERVICE_ADDR=user-service:8080

# ---- 天气工具(NWS api.weather.gov):User-Agent,建议填真实联系方式 ----
NWS_USER_AGENT=ai-chat (youjianxin-dating, contact@example.com)

# ---- 联网搜索:langchain-tavily + Jina Reader(r.jina.ai)----
TAVILY_API_KEY=your_tavily_api_key
# 可选:Jina Reader 不填 key 也能用(按 IP 限流)
# JINA_API_KEY=your_jina_api_key

# 可选:让 DH 改说指定语言(如 Chinese);留空=遵循 system.md 的 English only
# DH_REPLY_LANGUAGE=

# ---- Nacos 注册/发现(namespace 隔离学员×env)----
# 不配 NACOS_SERVER_ADDR 时回退 USER_SERVICE_ADDR 静态直连
NACOS_SERVER_ADDR=38.76.188.242:8848
NACOS_NAMESPACE=youjianxin-dating-dev
NACOS_GROUP=DEFAULT_GROUP
NACOS_SERVICE_NAME=ai-chat
NACOS_USERNAME=nacos
NACOS_PASSWORD=your_nacos_password
# 可选:显式指定注册到 Nacos 的本服务 IP(Docker 多网络时避免选错网卡)
# NACOS_SERVICE_IP=

# ---- PostgreSQL checkpointer(gRPC server 持久化对话历史,共用 youjianxin-dating-dev 库)----
PG_HOST=38.76.188.242
PG_PORT=5433
PG_DB=youjianxin-dating-dev
PG_USER=jianjian_test
PG_PASSWORD=your_pg_password
