# dev 部署环境变量模板。
# 复制为 deploy/.env.deploy 后填入真实值,**.env.deploy 不入 git**(红线 4)。
# 共享 dev 凭据见 docs/dev-onboarding.md §0,问管理员要。

# ---- PostgreSQL ----
PG_USERNAME=jianjian_test
PG_PASSWORD=

# ---- Redis ----
REDIS_HOST=38.76.188.242
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DATABASE=1

# ---- Nacos ----
NACOS_ADDR=38.76.188.242:8848
NACOS_NAMESPACE=dev-youjianxin
NACOS_USERNAME=nacos
NACOS_PASSWORD=

# ---- MinIO ----
MINIO_ENDPOINT=https://minio-api.jianjiange.site
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=dating-youjianxin

# ---- RocketMQ ----
# 见 docs/dev-onboarding §6.1;公网客户端必须带 AK/SK(§6.6),漏了会鉴权失败
ROCKETMQ_NAMESRV=38.76.188.242:9876
ROCKETMQ_AK=
ROCKETMQ_SK=

# ---- 雪花 ID(多实例必须不同) ----
SNOWFLAKE_WORKER_ID=1
