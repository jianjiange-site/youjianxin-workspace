# dev 部署环境变量模板。
# 复制为 deploy/.env.deploy 后填入真实值,**.env.deploy 不入 git**(红线 1)。
#
# 大部分连接信息已经移到 Nacos(workspace 仓库 nacos/dating-youjianxin-post-service-dev.yaml),
# 服务启动时从 Nacos 拉取,所以本机只需要 Nacos 自己的密码作为外部依赖。

# ---- Nacos(其他配置全部从 Nacos 拉取,Nacos 自己的密码是唯一外部依赖) ----
NACOS_PASSWORD=

# ---- 雪花 ID(可选,多实例部署时每个实例必须不同;单实例默认 1)----
SNOWFLAKE_WORKER_ID=1
