# dev 部署环境变量模板。
# 复制为 deploy/.env.deploy 后填入真实值,**.env.deploy 不入 git**(红线 1)。
#
# Java 服务(post/user/match/gateway)的连接信息全在 Nacos(namespace youjianxin-dating-dev),
# 启动时从 Nacos 拉,所以只需要 Nacos 自己的密码。
# ai-chat(Python)不读 Nacos 配置,PG / LLM key 走下面的变量。

# ---- Nacos(Java 服务 + ai-chat 共用;唯一必填项)----
NACOS_PASSWORD=

# ---- 雪花 ID(可选,多实例部署时每个实例必须不同;单实例默认 1)----
SNOWFLAKE_WORKER_ID=1

# ============================================================
# 以下仅 ai-chat 用(Python 服务直连 PG + 调 LLM)
# ============================================================

# ---- PostgreSQL checkpointer 密码(共享 dev 凭据,见 docs/dev-onboarding.md §0)----
PG_PASSWORD=

# ---- LLM key ----
# DeepSeek = DH 聊天(ChatAgent)。ChatDeepSeek 构造时要求**非空**,所以哪怕只是
# 让服务起来也要给个占位值(如 sk-REPLACE_ME);要真正能回复必须填真 key。
DEEPSEEK_API_KEY=sk-REPLACE_ME
# 以下为 vision(VisionAgent)多模态;全空则 VisionAgent 自动降级不注册,只跑 ChatAgent
GROQ_API_KEY=
GOOGLE_API_KEY=
ZAI_API_KEY=
# 联网搜索工具(可选)
TAVILY_API_KEY=
# LangSmith 追踪(可选)
LANGSMITH_API_KEY=
